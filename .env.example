PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://huanyu:huanyu_dev_password@localhost:5432/huanyu_medical
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=180000
OPENAI_REPORT_TIMEOUT_MS=240000
OPENAI_VISION_TIMEOUT_MS=180000

# Medical report-writing LLM. Fill this to route simple and professional report
# generation through AntAngelMed. OCR still uses the OPENAI_* vision settings above.
MEDICAL_LLM_PROVIDER=ant_ling
MEDICAL_LLM_API_KEY=
MEDICAL_LLM_BASE_URL=https://api.ant-ling.com/v1
MEDICAL_LLM_MODEL=AntAngelMed
MEDICAL_LLM_TIMEOUT_MS=180000
MEDICAL_LLM_STREAM=true
MEDICAL_LLM_RESPONSE_FORMAT=json_object
# Default true. When true, report generation fails visibly if the medical LLM
# cannot return a complete qualified report instead of silently using rules.
MEDICAL_LLM_STRICT_REPORTS=true
REPORT_GENERATION_LOG_DIR=logs

# OCR_PROVIDER:
# - auto: use OpenAI Vision when OPENAI_API_KEY is configured, then fallback to local tesseract.js
# - openai: require OpenAI Vision; do not silently fallback to low-quality local OCR
# - tesseract: local OCR only, suitable for offline smoke tests but not production medical report recognition
OCR_PROVIDER=auto
