PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://huanyu:huanyu_dev_password@localhost:5432/huanyu_medical
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=180000
OPENAI_REPORT_TIMEOUT_MS=240000
OPENAI_VISION_TIMEOUT_MS=180000

# Primary medical OCR for uploaded Chinese hospital reports.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_BASE_URL=https://aip.baidubce.com
BAIDU_OCR_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
BAIDU_OCR_TIMEOUT_MS=60000
# auto: choose diagnostic report vs lab report by filename; alternatives:
# health_report, medical_report_detection
BAIDU_MEDICAL_OCR_ENDPOINT=auto
# Structured medical OCR sometimes returns only field labels for overseas photos;
# shorter results are treated as unusable and continue to Baidu general OCR.
BAIDU_MEDICAL_OCR_MIN_TEXT_LENGTH=80
# Keep this enabled for overseas/free-form reports that Baidu medical structured
# OCR cannot extract. Requires 通用文字识别（标准版） or 高精度版 in Baidu console.
BAIDU_OCR_GENERAL_FALLBACK=true
# general_basic or accurate_basic
BAIDU_OCR_GENERAL_ENDPOINT=general_basic
# Used by general_basic. Keep CHN_ENG for mixed Chinese/English/Latin-script reports.
BAIDU_OCR_GENERAL_LANGUAGE=CHN_ENG

# Medical report-writing LLM. Fill this to route simple and professional report
# generation through AntAngelMed. Uploaded medical record OCR is configured separately.
MEDICAL_LLM_PROVIDER=ant_ling
MEDICAL_LLM_API_KEY=
MEDICAL_LLM_BASE_URL=https://api.ant-ling.com/v1
MEDICAL_LLM_MODEL=AntAngelMed
MEDICAL_LLM_TIMEOUT_MS=300000
MEDICAL_LLM_STREAM=true
MEDICAL_LLM_RESPONSE_FORMAT=json_object
# Default true. When true, report generation fails visibly if the medical LLM
# cannot return a complete qualified report instead of silently using rules.
MEDICAL_LLM_STRICT_REPORTS=true
REPORT_GENERATION_LOG_DIR=logs

# OCR_PROVIDER:
# - baidu_medical: primary production path for uploaded Chinese hospital reports
# - openai: require OpenAI Vision
# - auto: use OpenAI Vision when OPENAI_API_KEY is configured, then fallback to local tesseract.js
# - tesseract: local OCR only, suitable for offline smoke tests
OCR_PROVIDER=baidu_medical
# none by default to truly replace OpenAI/tesseract OCR. Baidu general OCR fallback
# is controlled separately by BAIDU_OCR_GENERAL_FALLBACK.
OCR_FALLBACK_PROVIDER=none
